# ── API Keys ─────────────────────────────────────────────────────────────────
# Set at least one of the following.  Models from that provider will appear
# automatically in the model selector.

# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# OPENROUTER_API_KEY=sk-or-...

# ── Directories ───────────────────────────────────────────────────────────────
# INBOX_DIR=./inbox
# OUTBOX_DIR=./outbox

# ── Server ────────────────────────────────────────────────────────────────────
# PORT=8080
# HOST=0.0.0.0
